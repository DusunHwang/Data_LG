# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=regression_platform
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# vLLM
VLLM_ENDPOINT_SMALL=http://your-vllm-server/v1
VLLM_MODEL_SMALL=your-model-name
VLLM_TEMPERATURE=0.1
VLLM_MAX_TOKENS=4000

# Artifact Store
ARTIFACT_STORE_ROOT=/data/app/artifacts
BUILTIN_DATASET_PATH=/app/datasets_builtin

# App
APP_ENV=development
LOG_LEVEL=INFO
MAX_UPLOAD_MB=100
MAX_SHAP_ROWS=5000
PLOT_SAMPLING_THRESHOLD_ROWS=200000
DEFAULT_SESSION_TTL_DAYS=7
DEFAULT_SUBSET_LIMIT=5
JOB_TIMEOUT_SECONDS=600
