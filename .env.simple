# SQLite DB 경로 (backend 실행 디렉토리 기준)
DATABASE_PATH=./data/app.db

# JWT
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# vLLM (엔드포인트와 모델명을 환경에 맞게 변경)
VLLM_ENDPOINT_SMALL=http://your-vllm-server/v1
VLLM_MODEL_SMALL=your-model-name
VLLM_TEMPERATURE=0.1
VLLM_MAX_TOKENS=4096

# 파일 저장 경로
ARTIFACT_STORE_ROOT=./data/artifacts
BUILTIN_DATASET_PATH=./datasets_builtin

# 앱 설정
APP_ENV=development
LOG_LEVEL=INFO
MAX_UPLOAD_MB=100
MAX_SHAP_ROWS=5000
PLOT_SAMPLING_THRESHOLD_ROWS=200000
DEFAULT_SESSION_TTL_DAYS=7
DEFAULT_SUBSET_LIMIT=5
JOB_TIMEOUT_SECONDS=600
COMPUTE_THREADS=8
WORKER_MAX_WORKERS=1
